{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "capacityos/indexes/domain-registry.schema.json",
  "title": "Domain Registry",
  "type": "object",
  "required": [
    "object_type",
    "id",
    "generated_at",
    "entries"
  ],
  "properties": {
    "object_type": {
      "const": "domain-registry"
    },
    "id": {
      "const": "domain-registry"
    },
    "generated_at": {
      "$ref": "./common.schema.json#/$defs/timestamp"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "domain_id",
          "name",
          "class",
          "status",
          "domain_ref",
          "review_profile",
          "starter_pack_ids"
        ],
        "properties": {
          "domain_id": {
            "$ref": "./common.schema.json#/$defs/slug"
          },
          "name": {
            "$ref": "./common.schema.json#/$defs/non_empty_string"
          },
          "class": {
            "$ref": "./common.schema.json#/$defs/slug"
          },
          "status": {
            "$ref": "./common.schema.json#/$defs/domain_status"
          },
          "domain_ref": {
            "$ref": "./common.schema.json#/$defs/domain_ref"
          },
          "review_profile": {
            "$ref": "./common.schema.json#/$defs/slug"
          },
          "starter_pack_ids": {
            "type": "array",
            "items": {
              "$ref": "./common.schema.json#/$defs/slug"
            },
            "uniqueItems": true
          },
          "key_goal_refs": {
            "type": "array",
            "items": {
              "$ref": "./common.schema.json#/$defs/goal_id"
            },
            "uniqueItems": true
          },
          "primary_state_packet_ref": {
            "$ref": "./common.schema.json#/$defs/domain_state_packet_ref"
          },
          "primary_steward_agent_id": {
            "$ref": "./common.schema.json#/$defs/agent_id"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
