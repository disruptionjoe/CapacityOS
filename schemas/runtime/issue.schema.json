{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "capacityos/runtime/issue.schema.json",
  "title": "Issue",
  "type": "object",
  "required": [
    "object_type",
    "id",
    "domain_id",
    "severity",
    "issue_type",
    "status",
    "created_at",
    "summary",
    "flow_effect",
    "lineage",
    "affected_refs",
    "impact_basis"
  ],
  "properties": {
    "object_type": {
      "const": "issue"
    },
    "id": {
      "type": "string",
      "pattern": "^issue-[a-z0-9][a-z0-9-]*$"
    },
    "domain_id": {
      "$ref": "./common.schema.json#/$defs/slug"
    },
    "severity": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9
    },
    "issue_type": {
      "enum": [
        "blocker",
        "risk",
        "contradiction"
      ]
    },
    "status": {
      "enum": [
        "open",
        "resolved",
        "superseded"
      ]
    },
    "created_at": {
      "$ref": "./common.schema.json#/$defs/timestamp"
    },
    "closed_at": {
      "$ref": "./common.schema.json#/$defs/timestamp"
    },
    "summary": {
      "$ref": "./common.schema.json#/$defs/non_empty_string"
    },
    "flow_effect": {
      "enum": [
        "improvement-only",
        "pause-affected",
        "escalate-human"
      ]
    },
    "goal_refs": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/goal_id"
      },
      "uniqueItems": true
    },
    "lineage": {
      "type": "object",
      "required": [
        "source_refs"
      ],
      "properties": {
        "source_refs": {
          "$ref": "./common.schema.json#/$defs/typed_ref_list"
        }
      },
      "additionalProperties": false
    },
    "affected_refs": {
      "$ref": "./common.schema.json#/$defs/typed_ref_list"
    },
    "impact_basis": {
      "$ref": "./common.schema.json#/$defs/closed_collision_basis"
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "enum": [
              "resolved",
              "superseded"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "closed_at"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "issue_type": {
            "const": "blocker"
          }
        },
        "required": [
          "issue_type"
        ]
      },
      "then": {
        "properties": {
          "flow_effect": {
            "enum": [
              "pause-affected",
              "escalate-human"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "issue_type": {
            "const": "contradiction"
          }
        },
        "required": [
          "issue_type"
        ]
      },
      "then": {
        "properties": {
          "flow_effect": {
            "enum": [
              "pause-affected",
              "escalate-human"
            ]
          },
          "affected_refs": {
            "minItems": 2
          }
        }
      }
    }
  ]
}
