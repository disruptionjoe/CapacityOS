{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "capacityos/runtime/queue-item.schema.json",
  "title": "Queue Item",
  "type": "object",
  "required": [
    "object_type",
    "id",
    "status",
    "domain_id",
    "title",
    "execution_mode",
    "lineage",
    "promotion",
    "assumptions_in_force",
    "collision_basis",
    "freshness",
    "supersession"
  ],
  "properties": {
    "object_type": {
      "const": "queue-item"
    },
    "id": {
      "type": "string",
      "pattern": "^queue-[a-z0-9][a-z0-9-]*$"
    },
    "status": {
      "enum": [
        "queued",
        "paused",
        "executing",
        "awaiting_review",
        "ready_for_consequence",
        "done",
        "superseded"
      ]
    },
    "domain_id": {
      "$ref": "./common.schema.json#/$defs/slug"
    },
    "title": {
      "$ref": "./common.schema.json#/$defs/non_empty_string"
    },
    "execution_mode": {
      "$ref": "./common.schema.json#/$defs/execution_mode"
    },
    "goal_refs": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/goal_id"
      },
      "uniqueItems": true
    },
    "lineage": {
      "type": "object",
      "required": [
        "source_refs"
      ],
      "properties": {
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "./common.schema.json#/$defs/backlog_ref"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "intake_refs": {
          "type": "array",
          "items": {
            "$ref": "./common.schema.json#/$defs/intake_ref"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "promotion": {
      "type": "object",
      "required": [
        "promoted_at",
        "basis",
        "readiness_basis"
      ],
      "properties": {
        "promoted_at": {
          "$ref": "./common.schema.json#/$defs/timestamp"
        },
        "basis": {
          "type": "array",
          "items": {
            "$ref": "./common.schema.json#/$defs/non_empty_string"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "readiness_basis": {
          "type": "array",
          "items": {
            "$ref": "./common.schema.json#/$defs/non_empty_string"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "assumptions_in_force": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/non_empty_string"
      },
      "uniqueItems": true
    },
    "collision_basis": {
      "$ref": "./common.schema.json#/$defs/closed_collision_basis"
    },
    "freshness": {
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "$ref": "./common.schema.json#/$defs/freshness_state"
        },
        "checked_at": {
          "$ref": "./common.schema.json#/$defs/timestamp"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "$ref": "./common.schema.json#/$defs/typed_ref"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "enum": [
                  "fresh",
                  "pause-for-retriage",
                  "superseded",
                  "escalate-to-human"
                ]
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "required": [
              "checked_at",
              "evidence_refs"
            ]
          }
        }
      ]
    },
    "supersession": {
      "type": "object",
      "required": [
        "relationship"
      ],
      "properties": {
        "relationship": {
          "$ref": "./common.schema.json#/$defs/supersession_relationship"
        },
        "by_refs": {
          "type": "array",
          "items": {
            "$ref": "./common.schema.json#/$defs/queue_ref"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "relationship": {
                "enum": [
                  "full-replacement",
                  "partial-replacement",
                  "invalidated-by-new-fact"
                ]
              }
            },
            "required": [
              "relationship"
            ]
          },
          "then": {
            "required": [
              "by_refs"
            ]
          }
        }
      ]
    },
    "supersedes": {
      "type": "object",
      "required": [
        "relationship",
        "target_refs"
      ],
      "properties": {
        "relationship": {
          "enum": [
            "full-replacement",
            "partial-replacement",
            "invalidated-by-new-fact"
          ]
        },
        "target_refs": {
          "type": "array",
          "items": {
            "$ref": "./common.schema.json#/$defs/queue_ref"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
