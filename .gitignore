# Engine-only repo rules for CapacityOS

# Local private canon, runtime, and colocated workspaces stay out of the
# publishable engine.
/local/

# Legacy nested workspace/repo kept only as a reference source while CapacityOS
# becomes the real repo root.
/JoeCapacityOS/

# Legacy local-state paths kept ignored during migration.
/runtime/
/imports/
/archive/
/attachments/
/private/

# Keep child repos out of the engine repo if older layouts are still present.
/projects/site/
/projects/caret-repo/

# Private or sensitive material
*.secret
*.env

# Editor / OS noise
.DS_Store
Thumbs.db
.obsidian/

# Build / cache noise
__pycache__/
.pytest_cache/
*.pyc
